# Application
APP_NAME="Public Payment Service"
ENVIRONMENT=production
DEBUG=false

# Database (use PostgreSQL in production)
DATABASE_URL=postgresql://user:password@localhost:5432/payment_service

# Security — MUST change in production
SECRET_KEY=replace-with-256-bit-random-key

# Payment limits
PAYMENT_EXPIRY_MINUTES=30
MAX_AMOUNT_PER_TRANSACTION=10000000

# SMTP (optional — emails are logged if not configured)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=secret
FROM_EMAIL=noreply@payment.service

# Optional provider credentials
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_MODE=live
